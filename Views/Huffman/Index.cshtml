@{
    ViewData["Title"] = "Huffman Coding";
}

<div class="space-y-6 animate-fade-in-up">
    <!-- Header -->
    <div class="glass-panel" style="padding: 1.5rem; border-radius: 1rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 style="font-size: 1.875rem; font-weight: bold; background: linear-gradient(135deg, #f472b6 0%, #f43f5e 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.25rem;">
                Huffman Coding
            </h1>
            <p style="color: #64748b; font-size: 0.875rem;">Greedy Compression Algorithm</p>
        </div>
        <div style="display: flex; gap: 1rem;">
            <button id="resetBtn" class="btn btn-secondary">Reset</button>
            <button id="buildBtn" class="btn btn-primary" style="background: linear-gradient(135deg, #ec4899 0%, #f43f5e 100%);">Build Tree</button>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
        <!-- Visualization Area -->
        <div class="glass-panel" style="padding: 2rem; border-radius: 1rem; min-height: 500px; max-height: 600px; overflow: auto;">
            <div style="min-width: 800px; min-height: 600px; display: flex; align-items: center; justify-content: center; position: relative;">
                <svg id="treeSvg" width="100%" height="100%" viewBox="0 0 1200 700" style="min-width: 800px;"></svg>
                <div id="emptyTreeMessage" style="position: absolute; color: #64748b; text-align: center; font-size: 0.875rem;">
                    Enter text and click "Build Tree" to visualize the structure.
                </div>
            </div>
        </div>

        <!-- Controls -->
        <div class="glass-panel" style="padding: 1.5rem; border-radius: 1rem; display: flex; flex-direction: column; gap: 1.5rem;">
            <div>
                <h3 style="font-size: 1.125rem; font-weight: 600; color: white; margin-bottom: 0.75rem;">Input Data</h3>
                <input id="inputText" type="text" value="banana" style="width: 100%; background: #1e293b; border: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem; padding: 0.75rem; color: white; font-size: 0.875rem;" placeholder="Enter string to compress..." />
            </div>

            <div id="codesSection" style="display: none;">
                <h3 style="font-size: 1.125rem; font-weight: 600; color: white; margin-bottom: 0.75rem;">Huffman Codes</h3>
                <div id="codesList" style="max-height: 16rem; overflow-y: auto;"></div>
            </div>

            <div id="statsSection" style="display: none; border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 1rem;">
                <div style="display: flex; justify-content: space-between; font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.5rem;">
                    <span>Original Size:</span>
                    <span id="originalSize">0 bits</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-size: 0.875rem; color: #94a3b8;">
                    <span>Compressed Size:</span>
                    <span id="compressedSize" style="color: #4ade80; font-weight: 600;">0 bits</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/huffman.js"></script>
}

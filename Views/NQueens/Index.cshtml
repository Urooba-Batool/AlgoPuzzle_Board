@{
    ViewData["Title"] = "N-Queens Visualizer";
}

<style>
    .chess-board {
        display: grid;
        gap: 2px;
        background: #1e293b;
        padding: 4px;
        border-radius: 0.5rem;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        border: 4px solid #334155;
    }
    
    .chess-square {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
    }
    
    .chess-square.light {
        background: #cbd5e1;
    }
    
    .chess-square.dark {
        background: #475569;
    }
    
    .chess-square:hover {
        transform: scale(1.05);
        filter: brightness(1.1);
    }
    
    .chess-square.unsafe {
        background: rgba(239, 68, 68, 0.3) !important;
        animation: pulse 1s infinite;
    }
    
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }
    
    .animate-bounce-in {
        animation: bounceIn 0.5s;
    }
    
    @@keyframes bounceIn {
        0% { transform: scale(0); }
        50% { transform: scale(1.2); }
        100% { transform: scale(1); }
    }
</style>

<div class="space-y-6 animate-fade-in-up">
    <!-- Header -->
    <div class="glass-panel" style="padding: 1.5rem; border-radius: 1rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 style="font-size: 1.875rem; font-weight: bold; background: linear-gradient(135deg, #a78bfa 0%, #ec4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.25rem;">
                N-Queens Visualizer
            </h1>
            <p style="color: #64748b; font-size: 0.875rem;">Backtracking Algorithm</p>
        </div>
        <div style="display: flex; gap: 1rem; align-items: center;">
            <span id="progressPercent" style="color: #94a3b8; font-size: 1.125rem; font-weight: 600;">0%</span>
            <button id="resetBtn" class="btn btn-secondary">
                Reset
            </button>
            <button id="solveBtn" class="btn btn-primary" style="background: linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%);">
                Auto Solve
            </button>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
        <!-- Chessboard -->
        <div class="glass-panel" style="padding: 2rem; border-radius: 1rem; display: flex; justify-content: center; align-items: center;">
            <div id="chessboard" class="chess-board" style="grid-template-columns: repeat(8, 1fr); width: 500px; height: 500px;"></div>
        </div>

        <!-- Stats Panel -->
        <div class="glass-panel" style="padding: 1.5rem; border-radius: 1rem; display: flex; flex-direction: column; gap: 1.5rem;">
            <div>
                <h3 style="font-size: 1.125rem; font-weight: 600; color: white; margin-bottom: 1rem;">Algorithm Stats</h3>
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.875rem; color: #94a3b8;">
                        <span>Board Size:</span>
                        <span id="boardSize" style="color: #a78bfa; font-weight: 600;">8 x 8</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.875rem; color: #94a3b8;">
                        <span>Queens Placed:</span>
                        <span id="queensPlaced" style="color: #60a5fa; font-weight: 600;">0 / 8</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.875rem; color: #94a3b8;">
                        <span>Backtracks:</span>
                        <span id="backtracks" style="color: #f472b6; font-weight: 600;">0</span>
                    </div>
                </div>
            </div>

            <div style="border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 1rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; color: white; margin-bottom: 0.75rem;">How it works</h3>
                <p style="font-size: 0.875rem; color: #94a3b8; line-height: 1.6; margin-bottom: 0.75rem;">
                    The algorithm places queens column by column. If a placement leads to a conflict, it
                    <span style="color: #f87171; font-weight: 600;">backtracks</span> to the previous step.
                </p>
                <div style="background: rgba(0, 0, 0, 0.3); padding: 0.75rem; border-radius: 0.5rem; font-family: 'Courier New', monospace; font-size: 0.75rem; color: #34d399; line-height: 1.6;">
                    isSafe(row, col) → Checks if queen is attacked<br/>
                    solve(row) → Try all cols for this row<br/>
                    recurse → solve(row + 1)
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/nqueens.js"></script>
}
